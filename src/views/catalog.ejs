<%- include('partials/header') %>

<main>
    <h1>Course Catalog</h1>

    <p> Browse available courses and click a course to view detailed information</p>

    <div class="course-list">
        <% Object.values(course).forEach(course => { %>
            <div class="course-card">
                <h3>
                    <a href="/catalog/<%= course.id %>">
                        <%= course.title %>
                    </a>
                </h3>

                <p class="course-id">
                    <%= course.id %> • <%= course.credits %> credits
                </p>

                <p class="course-description">
                    <%= course.description %>
                </p>
            </div>
        
        <% }) %>
    </div>

</main>

<%- include('partials/footer') %>